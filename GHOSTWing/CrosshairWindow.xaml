<Window x:Class="GHOSTWing.CrosshairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GHOSTWing Crosshair" Height="600" Width="600" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" IsHitTestVisible="False">
    <Grid>
        <Canvas x:Name="CrosshairCanvas" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Ellipse x:Name="FovCircle" Stroke="#8810B981" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" Stretch="Uniform"/>
    </Grid>
</Window>
