                            <Border BorderBrush="#27272A" BorderThickness="0,1,0,0" Margin="10,8"/>
                            <TextBlock Text="MARKETPLACE" FontSize="10" FontWeight="Bold" Foreground="#444444" Margin="12,0,0,10"/>
                            <RadioButton x:Name="NavVipCart" GroupName="SidebarNav" Style="{StaticResource NavButton}" Content="VIP CART" Tag="M5,16L3,5L8.5,10L12,4L15.5,10L21,5L19,16H5M19,19A1,1 0 0,1 18,20H6A1,1 0 0,1 5,19V18H19V19Z" Checked="NavCart_Checked"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Pages Container -->
                <Border Grid.Column="1" Background="#0D0D0F" CornerRadius="10" Padding="8" BorderBrush="#27272A" BorderThickness="1">
                    <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </ControlTemplate>
                        </TabControl.Template>

                        <!-- Page 0: Recoil Control -->
                        <TabItem>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- LEFT SIDE: Recoil settings + Start/Stop -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <!-- Recoil Settings -->
                                        <GroupBox Header="RECOIL CONFIGURATION" Style="{StaticResource CardGroupBox}">
                                            <Grid>
                                                <StackPanel>
                                                    <!-- Vertical -->
                                                    <Grid Margin="0,4,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="85"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="Vertical Pull:" Foreground="#71717A" FontSize="11.5"/>
                                                        <Slider Grid.Column="1" Name="sliderVertical" Minimum="0" Maximum="50" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="2" Text="{Binding ElementName=sliderVertical, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                                                    </Grid>
                                                    <!-- Horizontal -->
                                                    <Grid Margin="0,4,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="85"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="Horizontal:" Foreground="#71717A" FontSize="11.5"/>
                                                        <Slider Grid.Column="1" Name="sliderHorizontal" Minimum="-50" Maximum="50" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="2" Text="{Binding ElementName=sliderHorizontal, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                                                    </Grid>
                                                    <!-- Sleep Delay -->
                                                    <Grid Margin="0,4,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="85"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="Cycle Delay:" Foreground="#71717A" FontSize="11.5"/>
                                                        <Slider Grid.Column="1" Name="sliderDelay" Minimum="5" Maximum="50" Value="5" TickFrequency="1" SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="2" Text="{Binding ElementName=sliderDelay, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                                                    </Grid>
                                                    <Border Background="#05FFFFFF" CornerRadius="8" Padding="12">
                                                        <TextBlock Text="Optimal: 5ms for rapid fire. Use higher values (7ms+) for slower weapons or more stable recoil control." TextWrapping="Wrap" FontSize="11" Foreground="#888888" LineHeight="16"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Teaser Overlay -->
                                                <Border Name="overlayRecoil" Background="#AA000000" CornerRadius="12" Visibility="Collapsed">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="👑" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                        <TextBlock Text="PREMIUM RECOIL LOCKED" Foreground="#FAFAFA" FontSize="16" FontWeight="Black" HorizontalAlignment="Center"/>
                                                        <Button Content="UPGRADE NOW" Width="150" Height="35" Background="#10B981" Foreground="Black" FontWeight="Black" Margin="0,15,0,0" Click="btnGoToCart_Click"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </GroupBox>

                                        <!-- Control Panel -->
                                        <GroupBox Header="ENGINE CONTROLS" Style="{StaticResource CardGroupBox}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="160"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Left portion: Main Controls -->
                                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                                    <TextBlock Margin="0,0,0,10" Foreground="#52525B" FontSize="9.5" FontWeight="Bold" Text="ACTIVATION MODE"/>
                                                    <UniformGrid Columns="2" Margin="0,0,0,20">
                                                        <RadioButton Name="rbModeRightLeft" Content="Right+Left" IsChecked="True" Checked="rbModeRightLeft_Checked" GroupName="ActivationMode" FontSize="12"/>
                                                        <RadioButton Name="rbModeLeftOnly" Content="Left Only" Checked="rbModeLeftOnly_Checked" GroupName="ActivationMode" FontSize="12"/>
                                                    </UniformGrid>

                                                    <TextBlock Margin="0,0,0,10" Foreground="#52525B" FontSize="9.5" FontWeight="Bold" Text="HOTKEY CONFIGURATION"/>
                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#09090B" BorderBrush="#27272A" BorderThickness="1" CornerRadius="6" Height="35">
                                                            <TextBlock Name="txtToggleShortcut" Text="None" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Button Grid.Column="1" Content="RECORD" Width="90" Height="35" Margin="10,0,0,0" Style="{StaticResource RecordButtonStyle}" Click="btnSetToggleShortcut_Click"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                             <TextBlock Text="ENGINE STATUS:" Foreground="#52525B" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                             <ToggleButton Name="btnRecoilStatus" Style="{StaticResource StreamerToggleStyle}" Click="btnRecoilStatus_Click"/>
                                                             <Border Name="badgeVipEngine" Background="#1010B981" BorderBrush="#10B981" BorderThickness="1" CornerRadius="4" Padding="6,1" Margin="8,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                                                <TextBlock Text="VIP" Foreground="#10B981" FontSize="8" FontWeight="Black"/>
                                                             </Border>
                                                             <TextBlock Name="txtEngineStatus" Text="OFFLINE" Foreground="#D32F2F" FontWeight="Black" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                         </StackPanel>
                                                        <Button Grid.Column="1" Name="btnHide" Content="SEND TO TRAY" Width="120" Height="32" Background="#111111" Click="btnHide_Click" BorderBrush="#222222" FontSize="11"/>
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Right portion: Streamer Mode Box -->
                                                <Border Grid.Column="1" Background="#080808" CornerRadius="12" BorderBrush="#222222" BorderThickness="1" Padding="15">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="STEALTH MODE" FontSize="10" FontWeight="Black" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                                         <ToggleButton Name="btnStreamerMode" Style="{StaticResource StreamerToggleStyle}" Click="btnStreamerMode_Click" HorizontalAlignment="Center"/>
                                                         <Border Name="badgeVipStreamer" Background="#1010B981" BorderBrush="#10B981" BorderThickness="1" CornerRadius="4" Padding="6,1" Margin="0,5,0,0" Visibility="Collapsed" HorizontalAlignment="Center">
                                                            <TextBlock Text="VIP ONLY" Foreground="#10B981" FontSize="8" FontWeight="Black"/>
                                                         </Border>
                                                         <TextBlock Text="ANTI-CAPTURE" FontSize="9" Foreground="#666666" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="&amp; TASKBAR HIDE" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </GroupBox>
                                        <!-- Community & Files Section -->
                                        <GroupBox Header="COMMUNITY &amp; FILES" Style="{StaticResource CardGroupBox}">
                                            <StackPanel>
                                                <TextBlock Text="Share or load presets from other players." FontSize="11" Foreground="#B0B0B0" Margin="0,0,0,8"/>
                                                <UniformGrid Columns="2">
                                                    <Button Name="btnOpenFolder" Content="📂 Open Folder" Margin="0,0,4,0" Click="btnOpenFolder_Click" ToolTip="Open the settings folder in Windows Explorer."/>
                                                    <Button Name="btnImportPreset" Content="📥 Import JSON" Margin="4,0,0,0" Click="btnImportPreset_Click" ToolTip="Load a preset file from another player."/>
                                                </UniformGrid>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>

                                    <!-- RIGHT SIDE: Presets -->
                                    <StackPanel Grid.Column="1">
                                        <!-- Preset Management -->
                                        <GroupBox Header="Preset Management" Style="{StaticResource CardGroupBox}">
                                            <StackPanel>
                                                <!-- Preset Name -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Label Grid.Column="0" Content="Preset name:" Foreground="White"/>
                                                    <TextBox Grid.Column="1" Name="txtPresetName" Margin="6,0,0,0" ToolTip="Example: AK-47, M4, etc."/>
                                                </Grid>

                                                <!-- Shortcut row -->
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Label Grid.Column="0" Content="Shortcut key:" Foreground="White"/>
                                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                        <TextBox Name="txtShortcutKey" IsReadOnly="True" ToolTip="Click 'Set Key' and press a key." HorizontalContentAlignment="Center" Margin="0,0,0,4"/>
                                                        <UniformGrid Columns="2">
                                                            <Button Name="btnSetShortcut" Content="Set Key" Margin="0,0,4,0" Click="btnSetShortcut_Click"/>
                                                            <Button Name="btnDeleteShortcut" Content="Clear Key" Style="{StaticResource DangerButton}" Click="btnDeleteShortcut_Click"/>
                                                        </UniformGrid>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Action Buttons -->
                                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                                    <Button Name="btnSavePreset" Content="Save / Update" Style="{StaticResource PrimaryButton}" Click="btnSavePreset_Click" Margin="0,0,4,4"/>
                                                    <Button Name="btnDeletePreset" Content="Delete Preset" Style="{StaticResource DangerButton}" Click="btnDeletePreset_Click" Margin="4,0,0,4"/>
                                                </UniformGrid>
                                                <Button Name="btnDeleteAllShortcuts" Content="Clear All Global Shortcuts" Style="{StaticResource DangerButton}" Click="btnDeleteAllShortcuts_Click" Margin="0,4,0,0" ToolTip="Remove all shortcut keys from every preset."/>

                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Load Preset -->
                                        <GroupBox Header="Load Preset" Style="{StaticResource CardGroupBox}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <ComboBox Name="comboPresets" Margin="0,0,0,4" SelectionChanged="comboPresets_SelectionChanged" ToolTip="Choose a preset to load its settings."/>
                                                <TextBlock Text="Selecting a preset will update the sliders and shortcut." FontSize="11" Foreground="#B0B0B0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- App Info & Update Section -->
                                        <GroupBox Header="System Status" Style="{StaticResource CardGroupBox}">
                                            <StackPanel>
                                                <Grid Margin="0,4,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="App name:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                                        <TextBlock Text="Version:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                                        <TextBlock Text="Windows:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                                        <TextBlock Text=".NET:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                                        <TextBlock Text="Status:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="GHOSTWing Pro" FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                                        <TextBlock Name="txtAppVersion" Text="1.0.0" FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                                        <TextBlock Name="txtOSVersion" Text="Checking..." FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                                        <TextBlock Name="txtRuntimeVersion" Text="Checking..." FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                                        <TextBlock Name="txtUpdateStatus" Text="Ready to check" FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,4,0,8"/>

                                                <TextBlock Name="btnUpdateStatusTitle" Text="Check Update" FontSize="20" FontWeight="Black" Foreground="#52525B" HorizontalAlignment="Center" Margin="0,4" Cursor="Hand" MouseLeftButtonDown="CheckUpdate_Click">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Page 1: Crosshair Overlay -->
                        <TabItem>
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                                    <Grid Margin="0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="400"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="#09090B" CornerRadius="10" Margin="0,0,16,0" BorderBrush="#27272A" BorderThickness="1" MinHeight="{Binding ActualHeight, ElementName=crosshairCustomizerPanel}">
                                            <Grid>
                                                <TextBlock Text="CROSSHAIR PREVIEW" Foreground="#3F3F46" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"/>
                                                <Canvas x:Name="CrosshairPreview" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" x:Name="crosshairCustomizerPanel">
                                            <GroupBox Header="CROSSHAIR CUSTOMIZER" Style="{StaticResource CardGroupBox}">
                                                <StackPanel>
                                                    <Grid Margin="0,4,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="OVERLAY VISIBILITY" Foreground="#666666" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                            <ToggleButton Name="btnCrosshairEnable" Style="{StaticResource StreamerToggleStyle}" Click="btnCrosshairEnable_Click"/>
                                                            <Border Name="badgeVipCrossActive" Background="#1010B981" BorderBrush="#10B981" BorderThickness="1" CornerRadius="4" Padding="6,1" Margin="8,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                                                <TextBlock Text="VIP" Foreground="#10B981" FontSize="8" FontWeight="Black"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="GEOMETRY &amp; STYLE" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>

                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Content="Shape Type:" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="1" Name="comboCrosshairShape" SelectionChanged="CrosshairSetting_Changed">
                                                            <ComboBoxItem Content="Cross" IsSelected="True"/>
                                                            <ComboBoxItem Content="Circle"/>
                                                            <ComboBoxItem Content="Dot"/>
                                                            <ComboBoxItem Content="Cross + Circle"/>
                                                            <ComboBoxItem Content="Cross + Dot"/>
                                                        </ComboBox>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Content="Primary Color:" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="1" Name="comboCrosshairColor" SelectionChanged="CrosshairSetting_Changed">
                                                            <ComboBoxItem Content="Green" Foreground="#1DB954"/>
                                                            <ComboBoxItem Content="Red" Foreground="#D32F2F" IsSelected="True"/>
                                                            <ComboBoxItem Content="Cyan" Foreground="#00FFFF"/>
                                                            <ComboBoxItem Content="White" Foreground="White"/>
                                                            <ComboBoxItem Content="Yellow" Foreground="Yellow"/>
                                                        </ComboBox>
                                                    </Grid>

                                                    <TextBlock Text="DIMENSIONS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>

                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
