<Window x:Class="GHOSTWing.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="GHOSTWing" Icon="assets/icon.ico" Width="1200" SizeToContent="Height" MinHeight="680" ResizeMode="CanResize" Background="#000000" WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Card-like GroupBox style -->
        <Style x:Key="CardGroupBox" TargetType="GroupBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="#1F1F1F" CornerRadius="10" BorderBrush="#333333" BorderThickness="1" Padding="10">
                            <DockPanel>
                                <TextBlock Text="{TemplateBinding Header}" DockPanel.Dock="Top" Margin="0,0,0,8" Foreground="#D32F2F" FontWeight="SemiBold" FontSize="13"/>
                                <ContentPresenter/>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- General button style -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Black"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="Black"/>
                                <Setter Property="Foreground" Value="#777777"/>
                                <Setter Property="BorderBrush" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Labels -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <!-- TextBoxes -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- ComboBox: light look with black text -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- ComboBox items: black text, light background -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <!-- Modern Toggle Switch Style -->
        <Style x:Key="StreamerToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Background" Background="#444444" CornerRadius="12" BorderThickness="0"/>
                            <Ellipse x:Name="Dot" Fill="White" Width="18" Height="18" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="DotTransform" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#1DB954"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="DotTransform" Storyboard.TargetProperty="X" To="26" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="DotTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <!-- Center Title/Logo -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image Source="assets/logo.png" Width="42" Height="42" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Name="txtMainTitle" Text="GHOSTWing" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" Cursor="Hand" MouseLeftButtonDown="Title_Click" HorizontalAlignment="Center"/>
                    <TextBlock Text="Anti-recoil controller" FontSize="11" Foreground="White" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Version Badge (Remains on right) -->
            <Border VerticalAlignment="Center" HorizontalAlignment="Right" BorderBrush="#1DB954" BorderThickness="1.5" CornerRadius="15" Padding="12,4" Background="#1000FF00">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Name="txtBadgeArrow" Text="↓ " Visibility="Collapsed" Foreground="#1DB954" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Name="txtBadgeVersion" Text="v1.0.0" Foreground="#B0B0B0" FontSize="16" FontWeight="Black"/>
                </StackPanel>
            </Border>
        </Grid>l>

        <!-- Main Card -->
        <Border Grid.Row="1" Background="#050505" CornerRadius="12" Padding="12" BorderBrush="#222222" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: Recoil settings + Start/Stop -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <!-- Recoil Settings -->
                    <GroupBox Header="RECOIL CONFIGURATION" Style="{StaticResource CardGroupBox}" Margin="0,0,0,8">
                        <StackPanel>
                            <!-- Vertical -->
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Vertical:" Foreground="White"/>
                                <Slider Grid.Column="1" Name="sliderVertical" Minimum="0" Maximum="50" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding ElementName=sliderVertical, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" HorizontalContentAlignment="Center"/>
                            </Grid>

                            <!-- Horizontal -->
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Horizontal:" Foreground="White"/>
                                <Slider Grid.Column="1" Name="sliderHorizontal" Minimum="-50" Maximum="50" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding ElementName=sliderHorizontal, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" HorizontalContentAlignment="Center"/>
                            </Grid>

                            <!-- Sleep Delay -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Delay (ms):" Foreground="White"/>
                                <Slider Grid.Column="1" Name="sliderDelay" Minimum="5" Maximum="50" Value="5" TickFrequency="1" SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding ElementName=sliderDelay, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                            </Grid>

                            <TextBlock Margin="0,8,0,0" Text="Tip: 5ms is the optimal speed for shooting games. Use higher values (6ms, 7ms+) if the pull feels too fast. (Vertical/Horizontal values still support decimals for precision)." TextWrapping="Wrap" FontSize="11" Foreground="#B0B0B0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Control Panel -->
                    <GroupBox Header="Control Panel" Style="{StaticResource CardGroupBox}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left portion: Main Controls -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Margin="0,4,0,4" Foreground="#BBBBBB" FontSize="11" Text="Activation Mode:"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Name="btnModeRightLeft" Content="Hold Right + Left Mouse" MinWidth="160" Background="#1DB954" Click="btnModeRightLeft_Click" Margin="0,0,8,8"/>
                                    <Button Name="btnModeLeftOnly" Content="Hold Left Mouse" MinWidth="140" Background="Black" Click="btnModeLeftOnly_Click" Margin="0,0,8,8"/>
                                </WrapPanel>

                                <Grid Margin="0,16,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Toggle Key:"/>
                                    <WrapPanel Grid.Column="1">
                                        <TextBox Name="txtToggleShortcut" Width="100" IsReadOnly="True" HorizontalContentAlignment="Center"/>
                                        <Button Name="btnSetToggleShortcut" Content="Set Key" MinWidth="70" Margin="8,0,0,0" Background="Black" Click="btnSetToggleShortcut_Click"/>
                                        <Button Name="btnClearToggleShortcut" Content="Clear" MinWidth="60" Margin="8,0,0,0" Background="#D32F2F" Click="btnClearToggleShortcut_Click"/>
                                    </WrapPanel>
                                </Grid>

                                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                                    <Button Name="btnStart" Content="Start" MinWidth="100" Background="Black" Click="btnStart_Click" Margin="0,0,8,8"/>
                                    <Button Name="btnStop" Content="Stop" MinWidth="100" Background="#D32F2F" Click="btnStop_Click" Margin="0,0,8,8"/>
                                    <Button Name="btnHide" Content="Hide to Tray" MinWidth="110" Background="Black" Click="btnHide_Click" Margin="0,0,8,8"/>
                                </WrapPanel>
                            </StackPanel>

                            <!-- Right portion: Streamer Mode Box -->
                            <Border Grid.Column="1" Background="#0A0A0A" CornerRadius="10" BorderBrush="#333333" BorderThickness="1" Padding="15,10" Margin="15,0,0,0" MinWidth="130">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="STREAMER MODE" FontSize="10" FontWeight="Black" Foreground="#BBBBBB" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <ToggleButton Name="btnStreamerMode" Style="{StaticResource StreamerToggleStyle}" Click="btnStreamerMode_Click" HorizontalAlignment="Center" ToolTip="Enable full stealth (hides app content and taskbar icon)"/>
                                    <TextBlock Text="OFF / ON" FontSize="9" Foreground="#888888" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                    
                                    <TextBlock Text="Hides app from" FontSize="9" Foreground="#AAAAAA" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Capture &amp; Taskbar" FontSize="9" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </GroupBox>

                    <!-- Community & Files Section -->
                    <GroupBox Header="COMMUNITY &amp; FILES" Style="{StaticResource CardGroupBox}">
                        <StackPanel>
                            <TextBlock Text="Share or load presets from other players." FontSize="11" Foreground="#B0B0B0" Margin="0,0,0,8"/>
                            <UniformGrid Columns="2">
                                <Button Name="btnOpenFolder" Content="📂 Open Folder" Margin="0,0,4,0" Click="btnOpenFolder_Click" ToolTip="Open the settings folder in Windows Explorer."/>
                                <Button Name="btnImportPreset" Content="📥 Import JSON" Margin="4,0,0,0" Click="btnImportPreset_Click" ToolTip="Load a preset file from another player."/>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- RIGHT SIDE: Presets -->
                <StackPanel Grid.Column="1">
                    <!-- Preset Management -->
                    <GroupBox Header="Preset Management" Style="{StaticResource CardGroupBox}">
                        <StackPanel>
                            <!-- Preset Name -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Preset name:" Foreground="White"/>
                                <TextBox Grid.Column="1" Name="txtPresetName" Margin="6,0,0,0" ToolTip="Example: AK-47, M4, etc."/>
                            </Grid>

                            <!-- Shortcut row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Shortcut key:" Foreground="White"/>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBox Name="txtShortcutKey" IsReadOnly="True" ToolTip="Click 'Set Key' and press a key." HorizontalContentAlignment="Center" Margin="0,0,0,4"/>
                                    <UniformGrid Columns="2">
                                        <Button Name="btnSetShortcut" Content="Set Key" Margin="0,0,4,0" Click="btnSetShortcut_Click"/>
                                        <Button Name="btnDeleteShortcut" Content="Clear Key" Background="#D32F2F" Click="btnDeleteShortcut_Click"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>

                            <!-- Action Buttons -->
                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <Button Name="btnSavePreset" Content="Save / Update" Background="#1DB954" Click="btnSavePreset_Click" Margin="0,0,4,4"/>
                                <Button Name="btnDeletePreset" Content="Delete Preset" Background="#D32F2F" Click="btnDeletePreset_Click" Margin="4,0,0,4"/>
                            </UniformGrid>
                            <Button Name="btnDeleteAllShortcuts" Content="Clear All Global Shortcuts" Background="#D32F2F" Click="btnDeleteAllShortcuts_Click" Margin="0,4,0,0" ToolTip="Remove all shortcut keys from every preset."/>

                        </StackPanel>
                    </GroupBox>

                    <!-- Load Preset -->
                    <GroupBox Header="Load Preset" Style="{StaticResource CardGroupBox}" Margin="0,0,0,8">
                        <StackPanel>
                            <ComboBox Name="comboPresets" Margin="0,0,0,4" SelectionChanged="comboPresets_SelectionChanged" ToolTip="Choose a preset to load its settings."/>
                            <TextBlock Text="Selecting a preset will update the sliders and shortcut." FontSize="11" Foreground="#B0B0B0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- App Info & Update Section -->
                    <GroupBox Header="System Status" Style="{StaticResource CardGroupBox}">
                        <StackPanel>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="App name:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                    <TextBlock Text="Version:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                    <TextBlock Text="Status:" FontSize="11" Foreground="#B0B0B0" Margin="0,2"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="GHOSTWing Pro" FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                    <TextBlock Name="txtAppVersion" Text="1.0.0" FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                    <TextBlock Name="txtUpdateStatus" Text="Ready to check" FontSize="11" Foreground="#B0B0B0" FontWeight="SemiBold" Margin="0,2"/>
                                </StackPanel>
                            </Grid>

                            <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,4,0,8"/>

                            <TextBlock Name="btnUpdateStatusTitle" Text="Check Update" FontSize="22" FontWeight="Black" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,4" Cursor="Hand" MouseLeftButtonDown="CheckUpdate_Click">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Marquee Footer Section -->
        <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#222222" BorderThickness="0,1,0,0" Margin="-12,10,-12,-12" Padding="0,5">
            <Canvas Height="30" ClipToBounds="True" Background="Transparent">
                <TextBlock Name="txtMarquee" 
                           Text="GHOSTWing Produced by GHOST-404 | Checking for updates..." 
                           FontSize="14" FontWeight="Bold" FontStyle="Italic" Foreground="#1DB954" 
                           VerticalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="marqueeTransform" X="1200"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation 
                                        Storyboard.TargetName="marqueeTransform"
                                        Storyboard.TargetProperty="X"
                                        From="1200" To="-1500" 
                                        Duration="0:0:45"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Canvas>
        </Border>

    </Grid>
</Window>
