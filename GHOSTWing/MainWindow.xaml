                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <GroupBox Header="REMAINING TIME" Style="{StaticResource CardGroupBox}">
                                                    <StackPanel HorizontalAlignment="Center" Margin="0,15">
                                                        <Grid>
                                                            <Border Width="120" Height="120" CornerRadius="60" BorderBrush="#27272A" BorderThickness="8"/>
                                                            <Border Name="borderProgressCircle" Width="120" Height="120" CornerRadius="60" BorderBrush="#10B981" BorderThickness="8" ClipToBounds="True"/>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Name="txtAccDaysLeft" Text="--" Foreground="White" FontSize="32" FontWeight="Black" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="DAYS LEFT" Foreground="#71717A" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </GroupBox>

                                                <GroupBox Header="ACCOUNT SECURITY" Style="{StaticResource CardGroupBox}">
                                                    <StackPanel>
                                                        <TextBlock Text="This account is hardware-locked to your unique UUID. Sharing your account will result in a permanent HWID ban." Foreground="#F43F5E" FontSize="10" TextWrapping="Wrap" FontStyle="Italic"/>
                                                        <Button Content="COPY UNIQUE ID" Height="35" Margin="0,15,0,0" Click="CopyUUID_Click"/>
                                                    </StackPanel>
                                                </GroupBox>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </ScrollViewer>

                                <!-- Teaser Overlay -->
                                <Border Name="overlayAccount" Background="#AA000000" CornerRadius="12" Visibility="Collapsed">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="👑" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <TextBlock Text="ACCOUNT DETAILS HIDDEN" Foreground="#FAFAFA" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Membership status and HWID management requires a valid plan." Foreground="#71717A" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,20"/>
                                        <Button Content="UPGRADE IN VIP CART" Width="200" Height="40" Background="#10B981" Foreground="Black" FontWeight="Black" Click="btnGoToCart_Click"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- Tab 5: VIP CART -->
                        <TabItem Visibility="Collapsed">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                                    <TextBlock Text="GHOSTWing Marketplace" Foreground="#FAFAFA" FontSize="28" FontWeight="Black"/>
                                    <TextBlock Text="Choose the perfect plan for your gaming performance." Foreground="#71717A" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>

                                <UniformGrid Grid.Row="1" Columns="3">
                                    <!-- FREE CARD -->
                                    <Border Name="cardFree" Margin="8" Background="#111113" BorderBrush="#71717A" BorderThickness="1.5" CornerRadius="16" Padding="20">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="FREE USER" Foreground="#71717A" FontSize="14" FontWeight="Black" HorizontalAlignment="Center"/>
                                            <StackPanel Grid.Row="1" Margin="0,15,0,10">
                                                <TextBlock Name="txtFreePrice" Text="0.00$" Foreground="#FAFAFA" FontSize="34" FontWeight="Black" HorizontalAlignment="Center"/>
                                                <TextBlock Name="txtFreeDesc" Text="Standard engine access." Foreground="#A1A1AA" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                <StackPanel Name="panelFreeFeatures" Margin="0,10"/>
                                            </ScrollViewer>
                                            <Button Grid.Row="3" Name="btnFreeBuy" Content="CURRENT PLAN" Height="45" IsEnabled="False" Style="{StaticResource PrimaryButton}" Click="btnPlan_Click" Opacity="0.5"/>
                                        </Grid>
                                    </Border>

                                    <!-- GOLD CARD -->
                                    <Border Name="cardGold" Margin="8" Background="#111113" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="16" Padding="20">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="GOLD USER" Foreground="#F59E0B" FontSize="14" FontWeight="Black" HorizontalAlignment="Center"/>
                                            <StackPanel Grid.Row="1" Margin="0,15,0,10">
                                                <TextBlock Name="txtGoldPrice" Text="15.00$" Foreground="#FAFAFA" FontSize="34" FontWeight="Black" HorizontalAlignment="Center"/>
                                                <TextBlock Name="txtGoldDesc" Text="Enhanced precision &amp; priority." Foreground="#A1A1AA" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                <StackPanel Name="panelGoldFeatures" Margin="0,10"/>
                                            </ScrollViewer>
                                            <Button Grid.Row="3" Name="btnGoldBuy" Content="UPGRADE NOW" Height="45" Background="#F59E0B" Foreground="Black" FontWeight="Bold" Click="btnPlan_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="10"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- DIAMOND CARD -->
                                    <Border Name="cardDiamond" Margin="8" Background="#111113" BorderBrush="#06B6D4" BorderThickness="2" CornerRadius="16" Padding="20">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="DIAMOND USER" Foreground="#06B6D4" FontSize="14" FontWeight="Black" HorizontalAlignment="Center"/>
                                            <StackPanel Grid.Row="1" Margin="0,15,0,10">
                                                <TextBlock Name="txtDiamondPrice" Text="45.00$" Foreground="#FAFAFA" FontSize="34" FontWeight="Black" HorizontalAlignment="Center"/>
                                                <TextBlock Name="txtDiamondDesc" Text="Full elite suite &amp; support." Foreground="#A1A1AA" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                <StackPanel Name="panelDiamondFeatures" Margin="0,10"/>
                                            </ScrollViewer>
                                            <Button Grid.Row="3" Name="btnDiamondBuy" Content="GET ELITE" Height="45" Background="#06B6D4" Foreground="Black" FontWeight="Bold" Click="btnPlan_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="10"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <!-- Marquee Footer Section -->
            <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#222222" BorderThickness="0,1,0,0" Margin="-12,10,-12,-12" Padding="0,5">
                <Canvas Height="30" ClipToBounds="True" Background="Transparent">
                    <TextBlock Name="txtMarquee" Text="GHOSTWing Produced by GHOST-404 | Checking for updates..." FontSize="14" FontWeight="Bold" FontStyle="Italic" Foreground="#10B981" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="marqueeTransform" X="1200"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="marqueeTransform" Storyboard.TargetProperty="X" From="1200" To="-1500" Duration="0:0:45"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Canvas>
            </Border>
        </Grid>

        <!-- Notification Overlay (as before) -->
        <Grid x:Name="NotificationOverlay" Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0" Opacity="0" IsHitTestVisible="False">
            <Grid.RenderTransform>
                <TranslateTransform Y="-20"/>
            </Grid.RenderTransform>
            <Border x:Name="NotificationBorder" Background="#10B981" CornerRadius="20" Padding="25,10" BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtNotificationIcon" Text="✓" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtNotificationMessage" Text="Action Completed" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
            </Border>
        </Grid>

        <!-- Modern Update Modal Overlay -->
        <Grid x:Name="UpdateModal" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0">
            <!-- Semi-transparent background -->
            <Border Background="#CC000000" MouseLeftButtonDown="btnLater_Click"/>

            <Border Background="#1A1A1A" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="20" BorderBrush="#333333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#D32F2F" Opacity="0.2"/>
                </Border.Effect>

                <StackPanel Margin="30">
                    <Image Source="assets/logo.png" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,15" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="UPDATE AVAILABLE" Foreground="#D32F2F" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="A newer version of GHOSTWing is ready for you." Foreground="#AAAAAA" TextAlignment="Center" Margin="0,10,0,20" TextWrapping="Wrap"/>

                    <!-- Version Comparison -->
                    <Border Background="#111111" CornerRadius="10" Padding="15" Margin="0,0,0,25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="CURRENT" Foreground="#666666" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtCurrentVersionModal" Text="v1.0.0" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="→" Foreground="#D32F2F" FontSize="24" VerticalAlignment="Center" Margin="10,0"/>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="LATEST" Foreground="#666666" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtLatestVersionModal" Text="v1.1.0" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <Button Content="DOWNLOAD NOW" Click="btnDownloadNow_Click" Height="45" Background="#10B981" Foreground="White" BorderThickness="0" Margin="0,0,0,10" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Maybe Later" Click="btnLater_Click" Background="Transparent" Foreground="#888888" BorderThickness="0" Height="30">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
